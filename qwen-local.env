# Shared llama.cpp configuration for Codex, OpenClaw, and other clients.
# Install as ~/.config/qwen-local/qwen-local.env, then run qwen-local.sh fast
# or qwen-local.sh reasoning. Those commands only select reasoning off/on.

# Model catalog and download
QWEN_MODEL_CATALOG=$HOME/models/qwen-model-presets.json
MODEL_PRESET=qwen35-4b-q5km
MODEL_REPO=unsloth/Qwen3.5-4B-GGUF
MODEL_FILE=Qwen3.5-4B-Q5_K_M.gguf
MODEL_DIR=$HOME/models/qwen3.5-4b-q5km
MODEL=$MODEL_DIR/$MODEL_FILE
MODEL_SHA256=

# llama.cpp build and installed binaries
LLAMA_BACKEND=auto
LLAMA_DIR=$HOME/src/llama.cpp
LLAMA_CPP_REF=
LLAMA_CPP_COMMIT=
SERVER=$HOME/.local/bin/llama-server
CLI=$HOME/.local/bin/llama-cli

# Server runtime
HOST=127.0.0.1
PORT=18080
CTX=32768
NGL=999
MAX_TOKENS=4096
PARALLEL=1
BATCH=256
UBATCH=128
FLASH_ATTN=auto
REASONING_BUDGET=512
REASONING_FORMAT=deepseek
JINJA=on
OUTPUT_MODE=codex
CUSTOM_CHAT_TEMPLATE=
TUNE_TIMEOUT=120
